{
  "directory_name": "kakenhi-latex-makefile-boilerplate",
  "latex": [
    "uplatex",
    "platex"
  ],
  "character_encoding": [
    "utf",
    "sjis",
    "euc"
  ],
  "format_type": [
    "single",
    "multi"
  ],
  "document_type": [
    "2025_fall/ilr-1 [20260109] (utf/sjis/euc, single/multi)",
    "2025_fall/ilr-2 [20260109] (utf/sjis/euc, single/multi)",
    "2025_fall/ilr-3 [20260109] (utf/sjis/euc, single/multi)",
    "2025_fall/ilr-4 [20260109] (utf/sjis/euc, single/multi)",
    "2026_spring/dc [20260216] (utf/sjis/euc, single/multi)",
    "2026_spring/pd [20260216] (utf/sjis/euc, single/multi)",
    "2026_spring/rpd [20260216] (utf/sjis/euc, single/multi)",
    "2026_spring/orf [20260216] (utf/sjis/euc, single/multi)",
    "2026_spring/rra [20260216] (utf/sjis/euc, single/multi)",
    "2026_spring/startup [20260302] (utf/sjis/euc, single/multi)"
  ],
  "editor": [
    "VS Code with LaTeX Workshop extension",
    "Not specified"
  ],
  "indent": [
    "2 spaces",
    "4 spaces",
    "8 spaces",
    "Tab"
  ],
  "formatter": [
    "latexindent",
    "None"
  ],
  "linter": [
    "ChkTeX",
    "None"
  ],
  "_makefile_version": "0.13.0",
  "_jinja2_env_vars": {
    "lstrip_blocks": true,
    "trim_blocks": true
  },
  "_extensions": [
    "local_extensions.indent_string",
    "local_extensions.indent_editorconfig",
    "local_extensions.indent_vscode"
  ],
  "__prompts__": {
    "directory_name": "Select your project directory name",
    "document_name": "Select the main LaTeX file name (without .tex)",
    "editor": "Select your preferred LaTeX editor",
    "indent": "Select your preferred indentation style",
    "formatter": "Select your preferred LaTeX formatter",
    "linter": "Select your preferred LaTeX linter"
  }
}
